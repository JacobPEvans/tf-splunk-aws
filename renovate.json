{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "local>JacobPEvans/.github:renovate-presets"
  ],
  "packageRules": [
    {
      "description": "Automerge tflint-ruleset minor and patch updates (terraform-linters is canonical tflint org)",
      "matchManagers": ["terraform", "tflint"],
      "matchPackagePrefixes": ["terraform-linters/"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "squash"
    }
  ]
}
